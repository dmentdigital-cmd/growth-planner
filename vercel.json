{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/growth-planner-dmente.html"
    }
  ],
  "headers": [
    {
      "source": "/growth-planner-dmente.html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}
